rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function owns(uid) { return signedIn() && request.auth.uid == uid; }
    // Un usuario es miembro de una empresa si su propio doc en users/{uid}
    // tiene ese companyId. El acceso a vehicles/documents se define por esto,
    // no por ownerUid (ese campo ya no existe en el modelo multi-tenant).
    function isMember(companyId) {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId;
    }

    match /users/{uid} {
      allow read, write: if owns(uid);
    }

    match /companies/{companyId} {
      allow read, write: if isMember(companyId);
    }

    match /vehicles/{vehicleId} {
      allow read, delete: if isMember(resource.data.companyId);
      // En update se exige pertenencia tanto al companyId actual como al
      // entrante: evita que un miembro reasigne el documento a otra empresa
      // cambiando companyId en la escritura (companyId es inmutable entre empresas).
      allow update: if isMember(resource.data.companyId) && isMember(request.resource.data.companyId);
      allow create: if isMember(request.resource.data.companyId);
    }

    match /documents/{documentId} {
      allow read, delete: if isMember(resource.data.companyId);
      // Mismo criterio que en vehicles: companyId no puede cambiar a una
      // empresa de la que el usuario no sea miembro.
      allow update: if isMember(resource.data.companyId) && isMember(request.resource.data.companyId);
      allow create: if isMember(request.resource.data.companyId);
    }

    // Invitaciones: solo se acceden server-side (Admin SDK). Cliente sin acceso.
    match /invitations/{id} {
      allow read, write: if false;
    }

    // Padrón y bitácora: solo server-side (Admin SDK). Cliente sin acceso.
    match /drivers/{id} {
      allow read, write: if false;
    }
    match /usages/{id} {
      allow read, write: if false;
    }
  }
}
